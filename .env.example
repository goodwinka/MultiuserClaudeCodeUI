# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# Порт на хосте (http://localhost:PORT/)
PORT=80

# Путь на хосте для хранения данных (БД, проекты пользователей, настройки)
# По умолчанию: ./data (рядом с docker-compose.yml)
# Пример с абсолютным путём: DATA_DIR=/opt/ccode_data
DATA_DIR=./data

# Начальный пароль администратора
ADMIN_PASSWORD=admin123

# Секрет для подписи JWT — обязательно сменить в продакшне
JWT_SECRET=changeme-use-a-long-random-string

# API-ключ Claude / Anthropic
# Для облачного Claude: sk-ant-...
# Для локальной LLM (Ollama и т.п.): оставить "local"
ANTHROPIC_API_KEY=local

# Эндпоинт LLM (оставить пустым для облачного Claude)
# Для Ollama на хосте: http://host.docker.internal:11434/v1
ANTHROPIC_BASE_URL=http://host.docker.internal:11434/v1

# Таймаут бездействия сессии (минуты)
SESSION_TIMEOUT_MINUTES=30

# Макс. одновременных сессий (0 = без ограничений)
MAX_SESSIONS=0

# Прокси для git-операций (необязательно)
# GIT_PROXY_URL=http://host.docker.internal:34219
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1
